<?xml version="1.0" encoding="utf-8"?>
<!--
  PlayerView for the camera detail sheet's HLS playback. Uses a TextureView surface
  (surface_type=texture_view) instead of the default SurfaceView: a SurfaceView lives in
  its own window layer and renders BLACK under the bottom sheet's Haze blur / rounded clip
  (the snapshot still image composites fine, the live SurfaceView does not). A TextureView
  draws into the normal view hierarchy, so it composites correctly inside the sheet.
  resize_mode=zoom keeps the earlier behaviour: crop a sliver rather than pillarbox to fill
  the 16:9 box.
-->
<androidx.media3.ui.PlayerView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:surface_type="texture_view"
    app:resize_mode="zoom"
    app:use_controller="false" />
