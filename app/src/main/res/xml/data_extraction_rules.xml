<?xml version="1.0" encoding="utf-8"?><!--
   Exclude the auth DataStore (HA URL, SSIDs, access/refresh tokens) from Google cloud
   backups and device-to-device transfers: the long-lived Home Assistant token is stored
   there and must never leave the device. After a restore the user simply signs in again.
   Everything else (dashboard personalization, widget layouts) still backs up normally.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="datastore/auth.preferences_pb" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="datastore/auth.preferences_pb" />
    </device-transfer>
</data-extraction-rules>
