<?xml version="1.0" encoding="utf-8"?>
<!--
    Home Health adaptive-icon foreground — "Pulse House".
    A rounded house outline (taupe) with an ECG heartbeat line (sand) running
    through it: Home + Health. Palette and treatment match the companion
    "Caffeine Health" mark — soft greige line-art with a warm sand pulse on a
    clean white field — with the coffee cup swapped for a house. Stroked line-art
    with round caps/joins; content sits inside the central safe zone so it is
    never clipped by round / squircle launcher masks.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!-- House outline -->
    <path
        android:pathData="M54,33 L73,50 L73,75 L35,75 L35,50 Z"
        android:strokeColor="#A99C8C"
        android:strokeWidth="6.5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />
    <!-- Heartbeat / pulse -->
    <path
        android:pathData="M41,62 L51,62 L54,53 L57,72 L60,62 L67,62"
        android:strokeColor="#E6C8A3"
        android:strokeWidth="5.5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />
</vector>
