<?xml version="1.0" encoding="utf-8"?>
<!--
    Standalone "Pulse House" glyph (no background) for the Android 12+ splash icon and
    the in-app About hero. Palette matches the companion "Caffeine Health" mark — taupe
    house outline + warm sand pulse — with the coffee cup swapped for a house. The
    artwork is inset to the central ~2/3 of the canvas so it sits comfortably INSIDE
    the circular splash icon-background (the system masks the animated icon to a circle
    that only reveals the inner keyline). Same safe-zone proportions as
    ic_launcher_foreground, so launcher / splash / About all match.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!-- House outline -->
    <path
        android:pathData="M54,31 L71,47 L71,72 L37,72 L37,47 Z"
        android:strokeColor="#A99C8C"
        android:strokeWidth="6.5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />
    <!-- Heartbeat / pulse -->
    <path
        android:pathData="M43,60 L51,60 L54,52 L57,68 L60,60 L65,60"
        android:strokeColor="#E6C8A3"
        android:strokeWidth="5.5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />
</vector>
