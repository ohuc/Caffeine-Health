<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />
    <!-- Android 17 Local Network Protection: required to open TCP/UDP sockets to LAN IPs
         (e.g. Home Assistant at 192.168.x.x). Opt-in on Android 16, enforced on Android 17+. -->
    <uses-permission android:name="android.permission.ACCESS_LOCAL_NETWORK" />
    <!-- Wi-Fi Aware / Direct / RTT — not needed for plain TCP, kept for potential future
         on-device HA discovery (mDNS). Harmless if unused. -->
    <uses-permission android:name="android.permission.NEARBY_WIFI_DEVICES" />
    <!-- Required to read the connected Wi-Fi SSID so the app can decide between
         the user's local HA URL and a remote URL. Requested at runtime; without it
         the app silently falls back to the remote URL. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />

    <!-- Custom long-press waveform (double-tick "entered edit mode" buzz). VIBRATE is a
         normal permission — granted at install with no runtime prompt. -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Keep `update.install` work + the WebSocket alive (with a progress notification)
         while the app is closed, so updates finish after the user leaves. dataSync FGS,
         started from a user tap. POST_NOTIFICATIONS is runtime-requested on Android 13+. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Allow PackageManager.getLaunchIntentForPackage to see the HA Companion app
         on Android 11+ (package visibility). -->
    <queries>
        <package android:name="io.homeassistant.companion.android" />
        <package android:name="io.homeassistant.companion.android.minimal" />
    </queries>

    <application
        android:name=".HomeHealthApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.HomeHealth"
        android:enableOnBackInvokedCallback="true"
        android:usesCleartextTraffic="true"
        android:networkSecurityConfig="@xml/network_security_config">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.HomeHealth.Starting">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- WorkManager on-demand initialization: HomeHealthApplication provides the
             Hilt-aware Configuration, so the automatic startup initializer must be
             removed. Only the WorkManagerInitializer entry is dropped — lifecycle-process
             (ProcessLifecycleOwner) still initializes through androidx.startup. -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <!-- Background update installer. stopWithTask=false → survives swipe-away from
             Recents; the service stops itself once every tracked update finishes. -->
        <service
            android:name=".updates.UpdateInstallService"
            android:exported="false"
            android:foregroundServiceType="dataSync"
            android:stopWithTask="false" />
    </application>

</manifest>